APP_ENV=development
DATABASE_URL=mysql+pymysql://retail:2112@localhost:3306/retail_behavior
REDIS_URL=redis://localhost:6379/0
AUTH_SECRET=change-me
MASKING_DEFAULT=true
EXPORT_STORAGE_PATH=./var/exports
METRIC_FRESHNESS_MINUTES=5
ALERT_REFRESH_MINUTES=10
FRONTEND_API_BASE_URL=http://localhost:8000/api
# AI preference classification
AI_PREFERENCE_MODEL=BAAI/bge-small-zh-v1.5
AI_MODEL_CACHE_DIR=var/ai_models
