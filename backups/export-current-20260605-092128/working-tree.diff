+                    "alertType": "behavior_data_anomaly",
+                    "severity": "medium",
+                    "status": "new",
+                    "triggerReason": f"{channel_id} channel event flow is unusually low",
+                    "algorithmVersion": "retail-alert-v2",
+                }
+            )
+    return alerts
